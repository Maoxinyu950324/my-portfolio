---
interface Project {
  title: string;
  cover: string;
  description: string;
  category: string;
  slug: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

// Distribute projects across 3 columns in round-robin
const shuffled = [...projects].sort(() => Math.random() - 0.5);
const cols: Project[][] = [[], [], []];
shuffled.forEach((p, i) => cols[i % 3].push(p));
const speeds = [1.0, 0.7, 0.85]; // different scroll speeds per column
---

<section class="format-showcase">
  <div class="format-grid" id="format-grid">
    {cols.map((col, ci) => (
      <div class="format-column" data-speed={speeds[ci]}>
        <div class="format-column-track" id={`format-track-${ci}`}>
          {col.map((p) => (
            <a href={`/projects/${p.slug}`} class="format-card">
              <div class="format-card-image">
                {p.cover ? (
                  <img src={p.cover} alt={p.title} loading="lazy" />
                ) : (
                  <div class="format-placeholder">{p.title[0]}</div>
                )}
              </div>
              <p>{p.title}</p>
            </a>
          ))}
          <!-- Duplicate for seamless loop -->
          {col.map((p) => (
            <a href={`/projects/${p.slug}`} class="format-card" aria-hidden="true">
              <div class="format-card-image">
                {p.cover ? (
                  <img src={p.cover} alt={p.title} loading="lazy" />
                ) : (
                  <div class="format-placeholder">{p.title[0]}</div>
                )}
              </div>
              <p>{p.title}</p>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Gradient overlays -->
  <div class="format-gradient-top"></div>
  <div class="format-gradient-bottom"></div>
</section>

<style>
  .format-showcase {
    --format-image-nudge-x: -4.5%;
    position: relative;
    width: 100vw;
    height: 100vh;
    min-height: 620px;
    overflow: hidden;
    background: #0a0a0a;
    color: #f2f2f2;
    font-family: 'Inter', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    isolation: isolate;
  }

  .format-gradient-top,
  .format-gradient-bottom {
    position: absolute;
    right: 0;
    left: 0;
    z-index: 6;
    pointer-events: none;
  }
  .format-gradient-top {
    top: 0;
    height: clamp(80px, 12vh, 150px);
    background: linear-gradient(180deg, #0a0a0a 0%, rgba(10,10,10,0.72) 45%, transparent 100%);
  }
  .format-gradient-bottom {
    bottom: 0;
    height: clamp(80px, 12vh, 150px);
    background: linear-gradient(0deg, #0a0a0a 0%, rgba(10,10,10,0.72) 45%, transparent 100%);
  }

  .format-grid {
    position: absolute;
    top: 0;
    right: clamp(20px, 6vw, 80px);
    bottom: 0;
    left: clamp(20px, 6vw, 80px);
    z-index: 4;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2vw, 32px);
    overflow: hidden;
  }

  .format-column {
    position: relative;
    height: 100%;
    min-width: 0;
    overflow: hidden;
    cursor: default;
  }
  .format-column:hover .format-card {
    opacity: 1;
  }

  .format-column-track {
    display: grid;
    gap: clamp(16px, 2.5vh, 28px);
    padding-bottom: clamp(16px, 2.5vh, 28px);
    overflow-y: auto;
    height: 100%;
    scroll-behavior: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .format-column-track::-webkit-scrollbar { display: none; }

  .format-card {
    display: grid;
    justify-items: center;
    width: 100%;
    margin: 0;
    padding: clamp(14px, 1.8vw, 28px) clamp(12px, 1.6vw, 24px) clamp(10px, 1.4vw, 20px);
    background: #151515;
    opacity: 0.78;
    text-decoration: none;
    transition: opacity 0.22s ease;
    border-radius: 4px;
  }
  .format-column:hover .format-card { opacity: 0.94; }

  .format-card-image {
    display: grid;
    place-items: center;
    width: 100%;
    overflow: visible;
    background: #151515;
    transform: translate3d(var(--format-image-nudge-x), 0, 0);
  }
  .format-card img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }
  .format-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 3/4;
    background: #1a1a2e;
    color: #4a4a6a;
    font-size: 2rem;
    font-weight: 800;
  }

  .format-card p {
    margin: clamp(10px, 1vw, 18px) 0 0;
    overflow: hidden;
    color: #666;
    font-size: clamp(11px, 0.85vw, 16px);
    font-weight: 700;
    line-height: 1.1;
    text-align: center;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
  }

  /* Pause animation on hover */
  .format-column:hover .format-column-track {
    animation-play-state: paused;
  }

  @media (max-width: 760px) {
    .format-showcase {
      width: 100%;
      height: 100svh;
      min-height: 100svh;
      overflow: hidden;
    }
    .format-grid {
      right: 0;
      left: 0;
      display: flex;
      gap: 14px;
      padding: 0 18px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
    }
    .format-grid::-webkit-scrollbar { display: none; }

    .format-column {
      flex: 0 0 min(78vw, 320px);
      height: 100%;
      scroll-snap-align: center;
    }
    .format-column-track {
      animation: none;
      will-change: auto;
      overflow-y: auto;
      height: 100%;
      padding-bottom: 40px;
    }
    .format-column-track::-webkit-scrollbar { display: none; }

    .format-card {
      padding: 14px 14px 12px;
      opacity: 0.9;
    }
    .format-card-image {
      transform: translateZ(0);
    }
    .format-card p {
      margin-top: 8px;
      font-size: 11px;
    }
  }
</style>

<script>
  // Auto-scroll columns with opposite directions, plus mouse wheel support
  const columns = document.querySelectorAll('.format-column');

  const speeds = [0.4, -0.3, 0.35]; // px per frame, negative = reverse direction
  let scrolling = true;

  columns.forEach((col, ci) => {
    const track = col.querySelector('.format-column-track');
    if (!track) return;

    // Auto-scroll loop
    function autoScroll() {
      if (scrolling) {
        const halfHeight = track.scrollHeight / 2;
        track.scrollTop += speeds[ci];
        // Seamless loop: when reaching half, jump back
        if (speeds[ci] > 0 && track.scrollTop >= halfHeight) {
          track.scrollTop = 0;
        } else if (speeds[ci] < 0 && track.scrollTop <= 0) {
          track.scrollTop = halfHeight;
        }
      }
      requestAnimationFrame(autoScroll);
    }
    autoScroll();

    // Mouse wheel: pause auto, scroll manually, resume after 2s
    let wheelTimer;
    col.addEventListener('wheel', (e) => {
      e.preventDefault();
      e.stopPropagation();
      scrolling = false;

      const halfHeight = track.scrollHeight / 2;
      track.scrollTop += e.deltaY * 0.8;

      // Loop at boundaries
      if (track.scrollTop >= halfHeight) track.scrollTop = 0;
      if (track.scrollTop <= 0) track.scrollTop = halfHeight;

      clearTimeout(wheelTimer);
      wheelTimer = setTimeout(() => { scrolling = true; }, 2000);
    }, { passive: false });
  });
</script>
