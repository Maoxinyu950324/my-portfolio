---
import { loadSiteConfig } from '../config';
const config = loadSiteConfig();
const currentPath = Astro.url.pathname;
const links = [
  { href: '/#works', label: 'WORKS' },
  { href: '/about', label: 'ABOUT' },
  { href: 'mailto:your@email.com', label: 'CONTACT' },
];
---

<header style="position:fixed;top:0;left:0;right:0;z-index:9998;padding:20px 30px;display:flex;justify-content:space-between;align-items:center;mix-blend-mode:difference;">
  <a href="/" style="font-size:0.85rem;font-weight:600;color:#fff;letter-spacing:0.05em;">
    {config.siteName || 'PORTFOLIO'}
  </a>
  <nav style="display:flex;gap:24px;">
    {links.map(({ href, label }) => (
      <a href={href} class="nav-link" style={`font-size:0.75rem;font-weight:500;color:#999;letter-spacing:0.08em;${currentPath === href ? 'color:#fff;' : ''}`}>
        {label}
      </a>
    ))}
  </nav>
</header>
