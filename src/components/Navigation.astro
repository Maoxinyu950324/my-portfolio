---
import { loadSiteConfig } from '../config';
const config = loadSiteConfig();
const currentPath = Astro.url.pathname;
const links = [
  { href: '/#works', label: 'UI/UX DESIGN' },
  { href: '/#works', label: 'BRAND & VISUAL' },
  { href: '/about', label: 'ABOUT ME' },
];
---

<header style="position:fixed;top:0;left:0;right:0;z-index:9998;padding:20px 30px;display:flex;justify-content:space-between;align-items:center;mix-blend-mode:difference;">
  <a href="/" style="font-size:1.2rem;font-weight:700;color:#fff;letter-spacing:0.04em;">
    PORTFOLIO
  </a>
  <nav style="display:flex;gap:32px;">
    {links.map(({ href, label }) => (
      <a href={href} class="nav-link" style={`font-family:'Helvetica Neue', Helvetica, sans-serif;font-size:1.05rem;font-weight:400;color:#999;letter-spacing:0.02em;${currentPath === href ? 'color:#fff;' : ''}`}>
        {label}
      </a>
    ))}
  </nav>
</header>
