---
import { loadSiteConfig } from '../config';
const config = loadSiteConfig();
const currentPath = Astro.url.pathname;
const links = [
  { href: '/#brand', label: 'BRAND & VISUAL', tab: 'brand' },
  { href: '/#ui', label: 'UI/UX DESIGN', tab: 'ui' },
  { href: '/about', label: 'ABOUT ME' },
];
---

<header class="site-header">
  <a href="/" class="site-logo">
    PORTFOLIO
  </a>
  <nav class="site-nav">
    {links.map(({ href, label, tab }) => (
      <a href={href} class="nav-link" {...(tab ? { 'data-tab': tab } : {})} style={`${currentPath === href ? 'color:#fff;' : ''}`}>
        {label}
      </a>
    ))}
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9998;
    padding: 20px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    mix-blend-mode: difference;
  }
  .site-logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.04em;
    text-decoration: none;
  }
  .site-nav {
    display: flex;
    gap: 32px;
  }
  .site-nav .nav-link {
    font-family: 'Helvetica Neue', Helvetica, sans-serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: #999;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .site-header {
      padding: 12px 16px;
      align-items: flex-start;
    }
    .site-logo {
      font-size: 0.9rem;
    }
    .site-nav {
      flex-direction: column;
      align-items: flex-end;
      gap: 5px;
    }
    .site-nav .nav-link {
      font-size: 0.6rem;
    }
  }

  @media (max-width: 400px) {
    .site-nav {
      gap: 10px;
    }
    .site-nav .nav-link {
      font-size: 0.62rem;
      letter-spacing: 0.01em;
    }
  }
</style>
