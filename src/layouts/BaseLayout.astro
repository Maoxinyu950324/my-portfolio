---
import Navigation from '../components/Navigation.astro';
import { loadSiteConfig, generateColorVars } from '../config';

interface Props { title?: string; description?: string; }
const config = loadSiteConfig();
const { title = config.siteName, description = config.siteDescription } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content={config.siteKeywords} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
  <title>{title}</title>
  {config.customHead && <Fragment set:html={config.customHead} />}

  <!-- 背景音乐（循环播放，初始静音等待用户触发） -->
  <audio id="bg-music" loop preload="auto" style="display:none;">
    <source src="/audio/bg-music.mp3" type="audio/mpeg" />
  </audio>
</head>
<body class="cursor-none" style="background:#000;color:#e5e5e5;overflow-x:hidden;">
  <!-- 自定义光标 -->
  <div id="custom-cursor" aria-hidden="true" style="position:fixed;top:0;left:0;z-index:2147483647;width:28px;height:28px;pointer-events:none;transform:translate3d(-50%,-50%,0);opacity:0;visibility:hidden;mix-blend-mode:difference;">
    <svg viewBox="0 0 28 28" focusable="false" style="display:block;width:100%;height:100%;overflow:visible;filter:drop-shadow(0 0 6px rgba(255,255,255,0.3));">
      <path d="M14 5v18M5 14h18" stroke="#fff" stroke-width="1.5" stroke-linejoin="round" fill="none"/>
      <circle cx="14" cy="14" r="2" fill="#fff"/>
    </svg>
  </div>

  <Navigation />
  <slot />
</body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style is:inline>
  :root {
    {generateColorVars(config.primaryColor)}
    --color-bg: {config.bgColor};
    --color-text: {config.textColor};
    --font-sans: {config.bodyFont};
  }
</style>

{config.customCss && <style is:global set:html={config.customCss} />}

<script>
  // === 自定义光标 ===
  const cursor = document.getElementById('custom-cursor');
  const svg = cursor?.querySelector('svg');

  if (cursor && svg && window.matchMedia('(pointer: fine)').matches) {
    let mx = window.innerWidth / 2, my = window.innerHeight / 2;
    let cx = mx, cy = my;
    let angle = 0;
    let visible = false;

    function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

    function animate() {
      cx = lerp(cx, mx, 0.18);
      cy = lerp(cy, my, 0.18);
      cursor!.style.transform = `translate3d(${cx}px, ${cy}px, 0) rotate(${angle}deg)`;
      requestAnimationFrame(animate);
    }

    window.addEventListener('pointermove', (e) => {
      const dx = e.clientX - mx;
      const dy = e.clientY - my;
      if (Math.abs(dx) + Math.abs(dy) > 1) angle = Math.atan2(dy, dx) * (180 / Math.PI) + 45;
      mx = e.clientX; my = e.clientY;
      if (!visible) { visible = true; cursor!.style.visibility = 'visible'; cursor!.style.opacity = '1'; }
    }, { passive: true });

    window.addEventListener('pointerdown', () => { svg.style.transform = 'scale(0.82)'; });
    window.addEventListener('pointerup', () => { svg.style.transform = 'scale(1)'; });

    document.documentElement.addEventListener('mouseout', (e) => {
      if (!e.relatedTarget) { visible = false; cursor!.style.opacity = '0'; setTimeout(() => { if (!visible) cursor!.style.visibility = 'hidden'; }, 300); }
    });

    document.documentElement.addEventListener('mouseenter', () => {
      visible = true; cursor!.style.visibility = 'visible'; cursor!.style.opacity = '1';
    });

    requestAnimationFrame(animate);
  }
</script>
