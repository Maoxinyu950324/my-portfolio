---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const allProjects = await getCollection('projects', (e) => e.data.published === true);
const projects = allProjects
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p, i) => ({ title: p.data.title, cover: p.data.cover || '', category: p.data.category || '', slug: p.id, num: i + 1 }));

const introLines = ['MAOXINYU', 'DESIGN', 'PORTFOLIO'];
const allChars = [];
introLines.forEach((line, li) => {
  line.split('').forEach((char, ci) => allChars.push({ char, lineIndex: li, charIndex: ci }));
});
---

<BaseLayout title={config.siteName || 'PORTFOLIO'} description={config.siteDescription}>

  <!-- 蓝紫渐变实心球（follow cursor, mix-blend-mode:difference） -->
  <div id="cursor-blob" style="position:fixed;top:0;left:0;z-index:10000;pointer-events:none;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle at 35% 30%, #fff 0%, #14d6f7 25%, #5227ff 55%, #fa007b 100%);mix-blend-mode:difference;will-change:transform;opacity:0.95;filter:blur(4px);"></div>

  <!-- 开场全屏 -->
  <div id="intro-screen" style="position:fixed;inset:0;z-index:9999;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 0.6s ease, visibility 0.6s ease;">

    <!-- 标题 -->
    <h1 style="font-size:clamp(2.5rem, 10vw, 8rem);font-weight:900;color:#fff;text-align:center;line-height:1.1;letter-spacing:-0.02em;position:relative;z-index:10;">
      {introLines.map((line, li) => (
        <div style="display:block;">
          {line.split('').map((char, ci) => (
            <span class="intro-char" style={'animation-delay:' + (allChars.findIndex(c => c.lineIndex === li && c.charIndex === ci) * 0.06 + 0.4) + 's'}>
              {char}
            </span>
          ))}
        </div>
      ))}
    </h1>
    <!-- Shimmer 按钮 -->
    <button id="intro-btn" type="button" class="shimmer-btn" style="margin-top:3.5rem;position:relative;z-index:10001;isolation:isolate;">
      <span class="border-glow"></span>
      <span>START WITH SOUND</span>
    </button>
  </div>

  <!-- 主内容 -->
  <div id="main-content" style="opacity:0;transform:translateY(20px);transition:opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;">
    <div id="works" class="masonry-grid" style="padding:4px;">
      {projects.map((p) => (
        <a href={'/projects/' + p.slug} class="masonry-item">
          {p.cover ? (
            <img src={p.cover} alt={p.title} loading="lazy" />
          ) : (
            <div style="aspect-ratio:3/4;background:#1a1a1a;display:flex;align-items:center;justify-content:center;color:#333;font-size:2rem;font-weight:700;">{p.title[0]}</div>
          )}
          <div class="overlay">
            <span class="num">{p.num}</span>
            <span class="tt">{p.title}</span>
          </div>
        </a>
      ))}
    </div>
    <div style="padding:6rem 0;text-align:center;color:#444;font-size:0.75rem;letter-spacing:0.05em;">
      {config.copyright}
    </div>
  </div>
</BaseLayout>

<script>
  // === 开场按钮 ===
  (function() {
    var started = false;
    var btn = document.getElementById('intro-btn');
    var intro = document.getElementById('intro-screen');
    var main = document.getElementById('main-content');
    function startExperience() {
      if (started) return;
      started = true;
      var music = document.getElementById('bg-music');
      if (music) { music.volume = 0.3; music.play().catch(function(){}); }
      intro.style.opacity = '0';
      setTimeout(function() { intro.style.visibility = 'hidden'; }, 600);
      main.style.opacity = '1';
      main.style.transform = 'translateY(0)';
    }
    if (btn) btn.addEventListener('click', startExperience);
    document.addEventListener('keydown', function(e) {
      if (intro && intro.style.visibility !== 'hidden') startExperience();
    });
  })();

  // === 蓝紫渐变实心球跟随光标（mix-blend-mode:difference 反转） ===
  (function() {
    var blob = document.getElementById('cursor-blob');
    if (!blob) return;
    var mx = window.innerWidth / 2, my = window.innerHeight / 2;
    var cx = mx, cy = my, scale = 1;
    document.addEventListener('mousemove', function(e) {
      mx = e.clientX;
      my = e.clientY;
    });
    // 鼠标按下时略微收缩
    window.addEventListener('pointerdown', function() { scale = 0.75; });
    window.addEventListener('pointerup', function() { scale = 1; });
    function animate() {
      cx += (mx - cx) * 0.12;
      cy += (my - cy) * 0.12;
      blob.style.transform = 'translate3d(' + (cx - 90) + 'px, ' + (cy - 90) + 'px, 0) scale(' + scale + ')';
      requestAnimationFrame(animate);
    }
    animate();
  })();
</script>
