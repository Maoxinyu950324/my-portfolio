---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormatShowcase from '../components/FormatShowcase.astro';
import { getCollection } from 'astro:content';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const allProjects = await getCollection('projects', (e) => e.data.published === true);
const projects = allProjects
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p, i) => ({ title: p.data.title, cover: p.data.cover || '', category: p.data.category || '', slug: p.id, num: i + 1 }));

const introLines = ['MAOXINYU', 'DESIGN', 'PORTFOLIO'];
const allChars = [];
introLines.forEach((line, li) => {
  line.split('').forEach((char, ci) => allChars.push({ char, lineIndex: li, charIndex: ci }));
});
---

<BaseLayout title={config.siteName || 'PORTFOLIO'} description={config.siteDescription}>

  <!-- 开场全屏 -->
  <div id="intro-screen" style="position:fixed;inset:0;z-index:9999;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 0.6s ease, visibility 0.6s ease;">

    <!-- 实心渐变球（仅在开屏页） -->
    <div id="cursor-blob" style="position:fixed;top:0;left:0;z-index:10000;pointer-events:none;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle at 35% 30%, #fff 0%, #14d6f7 25%, #5227ff 55%, #fa007b 100%);mix-blend-mode:difference;will-change:transform;opacity:0.95;"></div>

    <!-- 标题 -->
    <h1 style="font-size:clamp(2.5rem, 10vw, 8rem);font-weight:900;color:#fff;text-align:center;line-height:1.1;letter-spacing:-0.02em;position:relative;z-index:10;">
      {introLines.map((line, li) => (
        <div style="display:block;">
          {line.split('').map((char, ci) => (
            <span class="intro-char" style={'animation-delay:' + (allChars.findIndex(c => c.lineIndex === li && c.charIndex === ci) * 0.06 + 0.4) + 's'}>
              {char}
            </span>
          ))}
        </div>
      ))}
    </h1>
    <!-- Shimmer 按钮 -->
    <button id="intro-btn" type="button" class="shimmer-btn" style="margin-top:3.5rem;position:relative;z-index:10001;isolation:isolate;">
      <span class="border-glow"></span>
      <span>START WITH SOUND</span>
    </button>
  </div>

  <!-- 主内容 -->
  <div id="main-content" style="opacity:0;transform:translateY(20px);transition:opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;">

    <!-- BRAND & VISUAL: 横向滚动画廊 -->
    <section id="brand" class="works-showcase tab-panel" data-tab="brand">
      <div class="works-gallery" id="works-gallery">
        <div class="works-track" id="works-track">
          {projects.map((p, i) => (
            <a
              href={'/projects/' + p.slug}
              class="work-card"
              data-index={i}
              data-title={p.title}
            >
              <div class="work-image-mask">
                {p.cover ? (
                  <img src={p.cover} alt={p.title} loading={i < 8 ? 'eager' : 'lazy'} />
                ) : (
                  <div class="work-placeholder">{p.title[0]}</div>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- UI/UX DESIGN: 三列自动滚动瀑布流 -->
    <div id="ui" class="tab-panel" data-tab="ui" style="display:none;">
      <FormatShowcase projects={projects} />
    </div>

    <div style="padding:6rem 0;text-align:center;color:#444;font-size:0.75rem;letter-spacing:0.05em;">
      {config.copyright}
    </div>
  </div>

  <!-- 底部信息栏 -->
  <div class="works-footer" id="works-footer" style="opacity:0;transition:opacity 0.4s ease 0.6s;">
    <span class="works-current-index" id="works-index">01</span>
    <p class="works-current-title" id="works-title">{projects[0]?.title || ''}</p>
    <span class="works-total">{String(projects.length).padStart(2, '0')}</span>
  </div>
</BaseLayout>

<script>
  // === 开场按钮 ===
  (function() {
    var started = false;
    var btn = document.getElementById('intro-btn');
    var intro = document.getElementById('intro-screen');
    var main = document.getElementById('main-content');
    var footer = document.getElementById('works-footer');
    function startExperience() {
      if (started) return;
      started = true;
      var music = document.getElementById('bg-music');
      if (music) { music.volume = 0.3; music.play().catch(function(){}); }
      intro.style.opacity = '0';
      setTimeout(function() { intro.style.visibility = 'hidden'; }, 600);
      main.style.opacity = '1';
      main.style.transform = 'translateY(0)';
      if (footer) { footer.style.opacity = '1'; }
    }
    if (btn) btn.addEventListener('click', startExperience);
    document.addEventListener('keydown', function(e) {
      if (intro && intro.style.visibility !== 'hidden') startExperience();
    });
  })();

  // === 实心渐变球（速度感应拉伸变形，渐变方向固定） ===
  (function() {
    var blob = document.getElementById('cursor-blob');
    var intro = document.getElementById('intro-screen');
    if (!blob || !intro) return;
    var mx = window.innerWidth / 2, my = window.innerHeight / 2;
    var cx = mx, cy = my;
    var prevX = mx, prevY = my;
    var vx = 0, vy = 0;
    var scaleX = 1, scaleY = 1;
    var pressScale = 1;

    document.addEventListener('mousemove', function(e) {
      mx = e.clientX;
      my = e.clientY;
    });
    window.addEventListener('pointerdown', function() { pressScale = 0.8; });
    window.addEventListener('pointerup', function() { pressScale = 1; });

    function animate() {
      if (intro.style.visibility === 'hidden') { blob.style.display = 'none'; return; }
      blob.style.display = '';

      var dx = mx - prevX;
      var dy = my - prevY;
      vx += (dx - vx) * 0.3;
      vy += (dy - vy) * 0.3;
      prevX = mx;
      prevY = my;

      var speed = Math.sqrt(vx * vx + vy * vy);
      var angle = Math.atan2(vy, vx);
      var stretch = Math.min(1 + speed * 0.025, 2.0);

      // 在屏幕坐标系下分解拉伸，不旋转球体，渐变方向固定不变
      var cosA = Math.cos(angle);
      var sinA = Math.sin(angle);
      var targetSX = pressScale * Math.sqrt(stretch * stretch * cosA * cosA + sinA * sinA / (stretch * stretch));
      var targetSY = pressScale * Math.sqrt(stretch * stretch * sinA * sinA + cosA * cosA / (stretch * stretch));
      scaleX += (targetSX - scaleX) * 0.08;
      scaleY += (targetSY - scaleY) * 0.08;

      cx += (mx - cx) * 0.08;
      cy += (my - cy) * 0.08;

      blob.style.transform =
        'translate3d(' + (cx - 100) + 'px, ' + (cy - 100) + 'px, 0) ' +
        'scaleX(' + scaleX + ') scaleY(' + scaleY + ')';

      requestAnimationFrame(animate);
    }
    animate();
  })();

  // === 横向滚动画廊 ===
  (function() {
    var gallery = document.getElementById('works-gallery');
    var track = document.getElementById('works-track');
    var cards = track ? track.querySelectorAll('.work-card') : null;
    var indexEl = document.getElementById('works-index');
    var titleEl = document.getElementById('works-title');

    if (!gallery || !cards || cards.length === 0) return;

    function getClosestCard() {
      var isMobile = window.innerWidth <= 760;
      var vpCenterX = window.innerWidth / 2;
      var vpCenterY = window.innerHeight / 2;
      var closest = null, closestIdx = 0, minDist = Infinity;
      cards.forEach(function(card, i) {
        var rect = card.getBoundingClientRect();
        var cardCenterX = rect.left + rect.width / 2;
        var cardCenterY = rect.top + rect.height / 2;
        // 桌面端用水平距离，移动端用垂直距离
        var dist = isMobile
          ? Math.abs(cardCenterY - vpCenterY)
          : Math.abs(cardCenterX - vpCenterX);
        if (dist < minDist) { minDist = dist; closest = card; closestIdx = i; }
      });
      return { card: closest, index: closestIdx };
    }

    function formatIdx(n) { return String(n + 1).padStart(2, '0'); }

    var isSnapping = false;
    var scrollTimer;

    function updateActive() {
      var r = getClosestCard();
      if (!r) return;
      cards.forEach(function(c) { c.classList.remove('is-active'); });
      r.card.classList.add('is-active');
      if (indexEl) indexEl.textContent = formatIdx(r.index);
      if (titleEl) titleEl.textContent = r.card.dataset.title || '';
    }

    function snapToClosest() {
      if (isSnapping || window.innerWidth <= 760) return;
      var r = getClosestCard();
      if (!r) return;
      var target = r.card.offsetLeft - gallery.offsetWidth / 2 + r.card.offsetWidth / 2;
      isSnapping = true;
      gallery.scrollTo({ left: target, behavior: 'smooth' });
      setTimeout(function() { isSnapping = false; }, 350);
    }

    gallery.addEventListener('scroll', function() {
      updateActive();
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(snapToClosest, 150);
    }, { passive: true });

    // 移动端垂直滚动时也更新序号
    window.addEventListener('scroll', function() {
      if (window.innerWidth <= 760) updateActive();
    }, { passive: true });

    window.addEventListener('resize', function() {
      updateActive();
      setTimeout(snapToClosest, 100);
    }, { passive: true });

    document.addEventListener('keydown', function(e) {
      var r = getClosestCard();
      if (!r) return;
      var idx = r.index;
      if (e.key === 'ArrowRight') idx = Math.min(r.index + 1, cards.length - 1);
      else if (e.key === 'ArrowLeft') idx = Math.max(r.index - 1, 0);
      else return;
      var targetCard = cards[idx];
      var targetScroll = targetCard.offsetLeft - gallery.offsetWidth / 2 + targetCard.offsetWidth / 2;
      gallery.scrollTo({ left: targetScroll, behavior: 'smooth' });
      cards.forEach(function(c) { c.classList.remove('is-active'); });
      targetCard.classList.add('is-active');
      if (indexEl) indexEl.textContent = formatIdx(idx);
      if (titleEl) titleEl.textContent = targetCard.dataset.title || '';
    });

    // 初始激活第一张
    if (cards[0]) cards[0].classList.add('is-active');
  })();

  // === Tab 切换（BRAND / UI 独立页面） ===
  (function() {
    var tabs = document.querySelectorAll('.nav-link[data-tab]');
    var panels = document.querySelectorAll('.tab-panel');
    var footer = document.getElementById('works-footer');

    function switchTab(tabName) {
      panels.forEach(function(p) {
        p.style.display = p.dataset.tab === tabName ? '' : 'none';
      });
      tabs.forEach(function(t) {
        t.classList.toggle('is-current', t.dataset.tab === tabName);
        t.style.color = t.dataset.tab === tabName ? '#fff' : '';
      });
      // Show footer only for brand tab
      if (footer) {
        footer.style.display = tabName === 'brand' ? '' : 'none';
      }
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function(e) {
        e.preventDefault();
        switchTab(tab.dataset.tab);
        // Update URL hash without scrolling
        history.replaceState(null, '', '#' + tab.dataset.tab);
      });
    });

    // Initial: respect URL hash
    var initHash = window.location.hash.replace('#', '');
    switchTab(initHash === 'ui' ? 'ui' : 'brand');

    // Handle back/forward browser buttons
    window.addEventListener('hashchange', function() {
      var hash = window.location.hash.replace('#', '');
      if (hash === 'brand' || hash === 'ui') switchTab(hash);
    });
  })();
</script>
