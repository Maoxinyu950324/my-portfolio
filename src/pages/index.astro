---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const homeContent = await getCollection('pages', (entry) => entry.slug === 'home');
const home = homeContent?.[0];

const allProjects = await getCollection('projects', (entry) => entry.data.published === true);
const projects = allProjects
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p) => ({
    title: p.data.title,
    cover: p.data.cover || '',
    description: p.data.description || '',
    category: p.data.category || '其他',
    slug: p.id,
  }));
---

<BaseLayout title="设计作品集 - 首页">
  <HeroSection
    title={home?.data.hero_title || 'Hi, I\'m Designer'}
    subtitle={home?.data.hero_subtitle || '用设计创造价值'}
    image={home?.data.hero_image || undefined}
  />
  <ProjectGrid projects={projects} limit={6} />
</BaseLayout>
