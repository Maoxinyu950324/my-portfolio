---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();

const allProjects = await getCollection('projects', (entry) => entry.data.published === true);
const projects = allProjects
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p) => ({
    title: p.data.title,
    cover: p.data.cover || '',
    description: p.data.description || '',
    category: p.data.category || '其他',
    slug: p.id,
  }));
---

<BaseLayout title={`${config.siteName} - 首页`} description={config.siteDescription}>
  <HeroSection
    title={config.heroTitle || "Hi, I'm Designer"}
    subtitle={config.heroSubtitle || '用设计创造价值'}
    image={config.heroBgImage || undefined}
  />
  <ProjectGrid projects={projects} limit={6} />
</BaseLayout>
