---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const allProjects = await getCollection('projects', (e) => e.data.published === true);
const projects = allProjects
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p, i) => ({ title: p.data.title, cover: p.data.cover || '', category: p.data.category || '', slug: p.id, num: i + 1 }));

const siteTitle = config.siteName || 'PORTFOLIO';
const words = siteTitle.split(' ');
const allChars: { char: string; wordIndex: number; charIndex: number }[] = [];
words.forEach((word, wi) => {
  word.split('').forEach((char, ci) => allChars.push({ char, wordIndex: wi, charIndex: ci }));
});
---

<BaseLayout title={siteTitle} description={config.siteDescription}>
  <!-- 动态背景光晕 -->
  <div id="bg-blob" style="position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;opacity:0.3;">
  </div>

  <!-- 开场全屏 -->
  <div id="intro-screen" style="position:fixed;inset:0;z-index:9999;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 0.8s ease, visibility 0.8s ease;">
    <h1 style="font-size:clamp(2.5rem, 10vw, 8rem);font-weight:900;color:#fff;text-align:center;line-height:1.15;letter-spacing:-0.02em;max-width:90vw;">
      {words.map((word, wi) => (
        <span style="display:inline-block;margin:0 0.2em;">
          {word.split('').map((char, ci) => (
            <span class="intro-char" style={`animation-delay:${(allChars.findIndex(c => c.wordIndex === wi && c.charIndex === ci)) * 0.07 + 0.4}s`}>
              {char}
            </span>
          ))}
        </span>
      ))}
    </h1>
    <button id="intro-btn" class="shimmer-btn" style="margin-top:3.5rem;">
      <span>Start with sound</span>
    </button>
  </div>

  <!-- 主内容 -->
  <div id="main-content" style="opacity:0;transform:translateY(20px);transition:opacity 0.8s ease, transform 0.8s ease;">
    <div id="works" class="masonry-grid" style="padding:4px;">
      {projects.map((p) => (
        <a href={`/projects/${p.slug}`} class="masonry-item">
          {p.cover ? (
            <img src={p.cover} alt={p.title} loading="lazy" />
          ) : (
            <div style="aspect-ratio:3/4;background:#1a1a1a;display:flex;align-items:center;justify-content:center;color:#333;font-size:2rem;font-weight:700;">{p.title[0]}</div>
          )}
          <div class="overlay">
            <span class="num">{p.num}</span>
            <span class="tt">{p.title}</span>
          </div>
        </a>
      ))}
    </div>
    <div style="padding:6rem 0;text-align:center;color:#444;font-size:0.75rem;letter-spacing:0.05em;">
      {config.copyright}
    </div>
  </div>
</BaseLayout>

<script>
  // === 背景光晕 ===
  const blob = document.getElementById('bg-blob');
  if (blob) {
    let mx = 0.5, my = 0.5;
    document.addEventListener('mousemove', (e) => {
      mx = e.clientX / window.innerWidth;
      my = e.clientY / window.innerHeight;
    });
    function updateBlob() {
      const x = mx * 100; const y = my * 100;
      blob.innerHTML = `<div style="position:absolute;top:${y-30}%;left:${x-30}%;width:60%;height:60%;background:radial-gradient(circle, rgba(99,102,241,0.15) 0%, rgba(236,72,153,0.08) 40%, transparent 70%);filter:blur(80px);border-radius:50%;transform:translate(${(mx-0.5)*20}px,${(my-0.5)*20}px);"></div>`;
      requestAnimationFrame(updateBlob);
    }
    updateBlob();
  }

  // === 开场动画 + 音乐触发 ===
  const btn = document.getElementById('intro-btn');
  const intro = document.getElementById('intro-screen');
  const main = document.getElementById('main-content');
  let started = false;

  async function startExperience() {
    if (started) return; started = true;
    try {
      const bgMusic = document.getElementById('bg-music') as HTMLAudioElement;
      if (bgMusic) { bgMusic.volume = 0.3; await bgMusic.play(); }
    } catch {}
    intro!.style.opacity = '0';
    intro!.style.visibility = 'hidden';
    main!.style.opacity = '1';
    main!.style.transform = 'translateY(0)';
  }

  btn?.addEventListener('click', startExperience);
  document.addEventListener('keydown', (e) => {
    if (intro && intro.style.visibility !== 'hidden') startExperience();
  });
</script>
