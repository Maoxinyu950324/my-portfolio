---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const allProjects = await getCollection('projects', (e) => e.data.published === true);
const projects = allProjects
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p, i) => ({ title: p.data.title, cover: p.data.cover || '', category: p.data.category || '', slug: p.id, num: i + 1 }));

const siteTitle = config.siteName || 'PORTFOLIO';
const words = siteTitle.split(' ');
const allChars = [];
words.forEach((word, wi) => {
  word.split('').forEach((char, ci) => allChars.push({ char, wordIndex: wi, charIndex: ci }));
});
---

<BaseLayout title={siteTitle} description={config.siteDescription}>
  <!-- 动态背景光晕 -->
  <div id="bg-blob" style="position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;opacity:0.25;"></div>

  <!-- 开场全屏 -->
  <div id="intro-screen" style="position:fixed;inset:0;z-index:9999;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 0.6s ease, visibility 0.6s ease;">
    <!-- 标题 -->
    <h1 style="font-size:clamp(2.5rem, 10vw, 8rem);font-weight:900;color:#fff;text-align:center;line-height:1.15;letter-spacing:-0.02em;max-width:90vw;">
      {words.map((word, wi) => (
        <span style="display:inline-block;margin:0 0.2em;">
          {word.split('').map((char, ci) => (
            <span class="intro-char" style={'animation-delay:' + (allChars.findIndex(c => c.wordIndex === wi && c.charIndex === ci) * 0.07 + 0.4) + 's'}>
              {char}
            </span>
          ))}
        </span>
      ))}
    </h1>
    <!-- Shimmer 按钮 -->
    <button id="intro-btn" type="button" class="shimmer-btn" style="margin-top:3.5rem;">
      <span>Start with sound</span>
    </button>

    <!-- 底部液态渐变 blob -->
    <div id="liquid-blob" style="position:absolute;bottom:-20%;left:50%;transform:translateX(-50%);width:80vw;height:50vh;pointer-events:none;">
      <div class="liquid-layer l1"></div>
      <div class="liquid-layer l2"></div>
      <div class="liquid-layer l3"></div>
    </div>
  </div>

  <!-- 主内容 -->
  <div id="main-content" style="opacity:0;transform:translateY(20px);transition:opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;">
    <div id="works" class="masonry-grid" style="padding:4px;">
      {projects.map((p) => (
        <a href={'/projects/' + p.slug} class="masonry-item">
          {p.cover ? (
            <img src={p.cover} alt={p.title} loading="lazy" />
          ) : (
            <div style="aspect-ratio:3/4;background:#1a1a1a;display:flex;align-items:center;justify-content:center;color:#333;font-size:2rem;font-weight:700;">{p.title[0]}</div>
          )}
          <div class="overlay">
            <span class="num">{p.num}</span>
            <span class="tt">{p.title}</span>
          </div>
        </a>
      ))}
    </div>
    <div style="padding:6rem 0;text-align:center;color:#444;font-size:0.75rem;letter-spacing:0.05em;">
      {config.copyright}
    </div>
  </div>
</BaseLayout>

<script>
  // === 背景光晕（鼠标跟随）===
  (function() {
    var blob = document.getElementById('bg-blob');
    var mx = 0.5, my = 0.5;
    document.addEventListener('mousemove', function(e) {
      mx = e.clientX / window.innerWidth;
      my = e.clientY / window.innerHeight;
    });
    function updateBlob() {
      if (!blob) return;
      var cx = mx * 100, cy = my * 100;
      blob.innerHTML = '<div style="position:absolute;top:'+(cy-30)+'%;left:'+(cx-30)+'%;width:60%;height:60%;background:radial-gradient(circle, rgba(99,102,241,0.15) 0%, rgba(236,72,153,0.08) 40%, transparent 70%);filter:blur(80px);border-radius:50%;transform:translate('+((mx-0.5)*20)+'px,'+((my-0.5)*20)+'px);"></div>';
      requestAnimationFrame(updateBlob);
    }
    updateBlob();
  })();

  // === 开场按钮 ===
  (function() {
    var started = false;
    var btn = document.getElementById('intro-btn');
    var intro = document.getElementById('intro-screen');
    var main = document.getElementById('main-content');

    function startExperience() {
      if (started) return;
      started = true;
      // 播放背景音乐
      var music = document.getElementById('bg-music');
      if (music) {
        music.volume = 0.3;
        music.play().catch(function(){});
      }
      // 渐出 intro
      intro.style.opacity = '0';
      setTimeout(function() {
        intro.style.visibility = 'hidden';
      }, 600);
      // 渐入 main
      main.style.opacity = '1';
      main.style.transform = 'translateY(0)';
    }

    if (btn) {
      btn.addEventListener('click', startExperience);
    }
    document.addEventListener('keydown', function(e) {
      if (intro && intro.style.visibility !== 'hidden') startExperience();
    });
  })();

  // === 底部液态 blob 动画 ===
  (function() {
    var t = 0;
    var layers = document.querySelectorAll('.liquid-layer');
    function animateLiquid() {
      t += 0.003;
      layers.forEach(function(el, i) {
        var phase = t + i * 2.1;
        var scaleX = 1 + Math.sin(phase * 0.7) * 0.25;
        var scaleY = 1 + Math.cos(phase * 0.6) * 0.25;
        var tx = Math.sin(phase) * 3;
        var ty = Math.cos(phase * 0.8) * 3;
        var opacity = 0.4 + Math.sin(phase * 1.3) * 0.15;
        el.style.transform = 'scaleX('+scaleX+') scaleY('+scaleY+') translate('+tx+'%,'+ty+'%)';
        el.style.opacity = opacity;
      });
      requestAnimationFrame(animateLiquid);
    }
    animateLiquid();
  })();
</script>

<style>
  /* 液态渐变 blob 层 */
  .liquid-layer {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    filter: blur(50px);
  }
  .liquid-layer.l1 {
    background: radial-gradient(circle at 32% 28%, #fff 0%, #14d6f7 25%, #5227ff 55%, #fa007b 100%);
    opacity: 0.5;
  }
  .liquid-layer.l2 {
    background: radial-gradient(circle at 60% 60%, #fa007b 0%, #5227ff 40%, #14d6f7 70%, transparent 100%);
    opacity: 0.35;
    transform: scale(1.3);
  }
  .liquid-layer.l3 {
    background: radial-gradient(circle at 45% 50%, #14d6f7 0%, #fff 30%, #fa007b 60%, transparent 100%);
    opacity: 0.25;
    transform: scale(1.5);
  }
</style>
