---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { loadSiteConfig } from '../../config';

const config = loadSiteConfig();
const allProjects = await getCollection('projects', (e) => e.data.published === true);
const projects = allProjects
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p, i) => ({
    title: p.data.title,
    cover: p.data.cover || '',
    slug: p.id,
    num: i + 1,
  }));
---

<BaseLayout title={`WORKS - ${config.siteName}`}>
  <div style="padding-top:70px;">
    <div class="masonry-grid" style="padding:4px;">
      {projects.map((p) => (
        <a href={`/projects/${p.slug}`} class="masonry-item">
          {p.cover ? (
            <img src={p.cover} alt={p.title} loading="lazy" />
          ) : (
            <div style="aspect-ratio:3/4;background:#2a2a2a;display:flex;align-items:center;justify-content:center;color:#555;font-size:2rem;">
              {p.title[0]}
            </div>
          )}
          <div class="overlay">
            <span class="num">{p.num}</span>
            <span class="tt">{p.title}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
