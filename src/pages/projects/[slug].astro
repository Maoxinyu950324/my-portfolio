---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { loadSiteConfig } from '../../config';

const config = loadSiteConfig();

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.published !== false);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.data.title} - ${config.siteName}`}>
  <article style="padding:100px 24px 80px;max-width:900px;margin:0 auto;">
    <a href="/#works" style="display:inline-flex;align-items:center;gap:6px;font-size:0.75rem;color:#666;letter-spacing:0.05em;margin-bottom:40px;transition:color 0.3s;" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='#666'">
      ← BACK
    </a>

    <span style="display:inline-block;border:1px solid #333;padding:4px 12px;font-size:0.7rem;color:#888;letter-spacing:0.05em;margin-bottom:16px;">
      {project.data.category}
    </span>

    <h1 style="font-size:clamp(1.5rem,4vw,2.5rem);font-weight:700;color:#fff;margin-bottom:12px;letter-spacing:-0.02em;">
      {project.data.title}
    </h1>

    <p style="color:#888;font-size:0.9rem;line-height:1.6;margin-bottom:40px;">
      {project.data.description}
    </p>

    {project.data.tags && project.data.tags.length > 0 && (
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:48px;">
        {project.data.tags.map((tag: string) => (
          <span style="font-size:0.7rem;color:#555;padding:2px 10px;border:1px solid #2a2a2a;">{tag}</span>
        ))}
      </div>
    )}

    {project.data.cover && (
      <img src={project.data.cover} alt={project.data.title} style="width:100%;height:auto;margin-bottom:4px;" />
    )}

    {project.data.gallery && project.data.gallery.length > 0 && (
      <div style="margin-top:4px;">
        {project.data.gallery.map((item: { image: string; caption?: string }) => (
          <figure style="margin-bottom:4px;">
            <img src={item.image} alt={item.caption || ''} style="width:100%;height:auto;" loading="lazy" />
            {item.caption && <figcaption style="text-align:center;font-size:0.75rem;color:#666;padding:12px 0;">{item.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    {project.rendered?.html && (
      <div style="margin-top:48px;color:#aaa;line-height:1.8;font-size:0.9rem;" set:html={project.rendered.html} />
    )}
  </article>
</BaseLayout>
