---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.published !== false);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.data.title} - 设计作品集`}>
  <article class="py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6">
      <a
        href="/projects"
        class="inline-flex items-center gap-1 text-sm text-neutral-500 transition hover:text-neutral-900 mb-8"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        返回作品列表
      </a>

      <div class="flex items-center gap-3 mb-4">
        <span class="rounded-full bg-brand-100 px-3 py-1 text-xs font-medium text-brand-700">
          {project.data.category}
        </span>
        <span class="text-sm text-neutral-400">
          {new Date(project.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
      </div>

      <h1 class="text-4xl font-bold tracking-tight md:text-5xl mb-4">
        {project.data.title}
      </h1>

      <p class="text-lg text-neutral-600 mb-6">
        {project.data.description}
      </p>

      {project.data.tags && project.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12">
          {project.data.tags.map((tag: string) => (
            <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs text-neutral-600">{tag}</span>
          ))}
        </div>
      )}

      {project.data.cover && (
        <div class="mb-12 overflow-hidden rounded-2xl">
          <img src={project.data.cover} alt={project.data.title} class="h-auto w-full" />
        </div>
      )}

      {project.data.gallery && project.data.gallery.length > 0 && (
        <div class="mb-12 space-y-6">
          {project.data.gallery.map((item: { image: string; caption?: string }) => (
            <figure class="space-y-3">
              <div class="overflow-hidden rounded-xl">
                <img src={item.image} alt={item.caption || ''} class="h-auto w-full" loading="lazy" />
              </div>
              {item.caption && <figcaption class="text-center text-sm text-neutral-500">{item.caption}</figcaption>}
            </figure>
          ))}
        </div>
      )}

      {project && (
        <div class="prose prose-lg prose-neutral mx-auto max-w-none">
          <div set:html={project.rendered?.html} />
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose img { @apply rounded-xl; }
  .prose a { @apply text-brand-600 underline decoration-brand-300 underline-offset-4 transition hover:text-brand-700; }
</style>
