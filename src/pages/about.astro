---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
---

<BaseLayout title={`ABOUT - ${config.siteName}`}>
  <section style="padding:120px 24px 80px;max-width:700px;margin:0 auto;">
    {config.showAvatar && config.avatarUrl && (
      <img src={config.avatarUrl} alt="" style="width:80px;height:80px;border-radius:50%;object-fit:cover;margin-bottom:40px;" />
    )}

    <h1 style="font-size:clamp(1.5rem,4vw,2.5rem);font-weight:700;color:#fff;margin-bottom:32px;letter-spacing:-0.02em;">
      ABOUT
    </h1>

    {config.aboutContent && (
      <div style="color:#aaa;line-height:1.8;font-size:0.9rem;white-space:pre-wrap;margin-bottom:48px;">
        {config.aboutContent}
      </div>
    )}

    {config.socialLinks && config.socialLinks.length > 0 && (
      <div style="display:flex;flex-wrap:wrap;gap:16px;">
        {config.socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            style="padding:8px 20px;border:1px solid #333;font-size:0.75rem;color:#888;letter-spacing:0.05em;transition:all 0.3s;"
            onmouseenter="this.style.borderColor='#fff';this.style.color='#fff'"
            onmouseleave="this.style.borderColor='#333';this.style.color='#888'"
          >
            {link.label || link.platform}
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
